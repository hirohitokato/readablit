{
  "manifest_version": 3,
  "name": "Readablit",
  "description": "日本語テキストに分かち書き風の間隔とルビを付けて読みやすくする拡張機能です。",
  "version": "1.0.0",
  "icons": {
    "128": "hello_extensions.png"
  },
  "action": {
    "default_title": "Readablit",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "hello_extensions.png"
    }
  },
  "background": {
    "service_worker": "background/serviceWorker.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dict/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
